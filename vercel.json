{
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "env": {
    "NODE_VERSION": "18.20.8"
  },
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-UA-Compatible",
          "value": "IE=edge"
        },
        {
          "key": "Viewport",
          "value": "width=device-width, initial-scale=1.0, maximum-scale=5.0"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
